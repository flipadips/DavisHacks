@keyframes expand {
    0% {
        width: 0;
        opacity: 0;
        left: 0;
    }

    100% {
        width: 100%;
        opacity: 1;
        left: 0;
    }
}

@keyframes collapse {
    0% {
        width: 100%;
        opacity: 1;
        left: 0;
    }

    100% {
        width: 0;
        left: 100%;
    }
}
