				<div class="elementor-widget-container">
							<div class="elementor-shortcode"><h3>Select A Service</h3><form method="GET" id="serviceDropdownForm"><select id="serviceDropdown"><option value="">Select a Related Service</option><option value="https://www.mmchs.org/services/audiology/">Audiology</option><option value="https://www.mmchs.org/services/ear-nose-throat/">Ear, Nose &amp; Throat (ENT)</option><option value="https://www.mmchs.org/services/laboratory-and-pathology/">Laboratory and Pathology</option><option value="https://www.mmchs.org/services/mammography/">Mammography</option><option value="https://www.mmchs.org/services/massage-therapy/">Massage Therapy</option><option value="https://www.mmchs.org/services/occupational-medicine/">Occupational Medicine</option><option value="https://www.mmchs.org/services/occupational-therapy/">Occupational Therapy</option><option value="https://www.mmchs.org/services/orthopedics/">Orthopedics</option><option value="https://www.mmchs.org/services/physical-therapy/">Physical Therapy</option><option value="https://www.mmchs.org/services/radiology/">Radiology</option><option value="https://www.mmchs.org/services/speech-therapy/">Speech Therapy</option><option value="https://www.mmchs.org/?page_id=1275">Sports Medicine</option></select><button type="button" id="goButton">Go <i class="fas fa-chevron-right"></i></button></form><script type="text/javascript">
        jQuery(document).ready(function($) {
            $("#goButton").click(function() {
                var selectedOption = $("#serviceDropdown").val();
                if (selectedOption !== "") {
                    window.location.href = selectedOption;
                }
            });
        });        
        </script></div>
						</div>
				</div>
